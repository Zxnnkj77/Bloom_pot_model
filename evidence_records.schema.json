{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "evidence_records.schema.json",
  "title": "Bloom Pot Evidence Records",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "plant_id",
      "attribute_name",
      "value",
      "unit",
      "evidence_class",
      "source_kind",
      "source_reference",
      "observed_at",
      "recorded_at",
      "notes",
      "provenance"
    ],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
      },
      "plant_id": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
      },
      "attribute_name": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
      },
      "value": {
        "type": [
          "string",
          "number",
          "boolean",
          "null"
        ]
      },
      "unit": {
        "type": [
          "string",
          "null"
        ],
        "minLength": 1
      },
      "evidence_class": {
        "type": "string",
        "enum": [
          "legacy_backed",
          "experimental_observation",
          "inferred",
          "unresolved"
        ]
      },
      "source_kind": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
      },
      "source_reference": {
        "type": "string",
        "minLength": 1
      },
      "observed_at": {
        "type": [
          "string",
          "null"
        ],
        "format": "date-time"
      },
      "recorded_at": {
        "type": "string",
        "format": "date-time"
      },
      "notes": {
        "type": "string"
      },
      "provenance": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "import_batch",
          "imported_at",
          "imported_by",
          "ingest_method"
        ],
        "properties": {
          "import_batch": {
            "type": "string",
            "minLength": 1
          },
          "imported_at": {
            "type": "string",
            "format": "date-time"
          },
          "imported_by": {
            "type": "string",
            "minLength": 1
          },
          "ingest_method": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
          }
        }
      }
    }
  }
}
