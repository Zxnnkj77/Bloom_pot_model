{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "evidence_records.schema.json",
  "title": "Bloom Pot Evidence Records",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "plant_id",
      "attribute_name",
      "evidence_class",
      "value",
      "provenance"
    ],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
      },
      "plant_id": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
      },
      "attribute_name": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
      },
      "evidence_class": {
        "type": "string",
        "enum": [
          "legacy_migrated_value",
          "controller_profile_value",
          "replay_derived_observation",
          "derived_inference"
        ]
      },
      "value": {
        "anyOf": [
          {
            "type": [
              "string",
              "number",
              "boolean",
              "null"
            ]
          },
          {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        ]
      },
      "provenance": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_file",
          "source_type",
          "detail"
        ],
        "properties": {
          "source_file": {
            "type": "string",
            "minLength": 1
          },
          "source_type": {
            "type": "string",
            "enum": [
              "plant_facts_record",
              "unresolved_species_record",
              "controller_profile_record",
              "replay_fixture",
              "derived_from_evidence"
            ]
          },
          "detail": {
            "type": "string",
            "minLength": 1
          },
          "source_record_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
          },
          "source_controller_family": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
          },
          "source_scenario_id": {
            "type": "string",
            "minLength": 1
          },
          "supporting_evidence_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
            }
          },
          "derivation": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
