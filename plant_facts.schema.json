{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "plant_facts.schema.json",
  "title": "Bloom Pot Plant Facts",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "common_name",
      "scientific_name",
      "identity_provenance",
      "controller_family",
      "controller_assignment"
    ],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
      },
      "common_name": {
        "type": "string",
        "minLength": 1
      },
      "scientific_name": {
        "type": "string",
        "minLength": 1
      },
      "identity_provenance": {
        "$ref": "#/$defs/identityProvenance"
      },
      "controller_family": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
      },
      "controller_assignment": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "review_status",
          "evidence_level",
          "derived_from_attributes",
          "special_handling",
          "manual_review_reasons",
          "provenance"
        ],
        "properties": {
          "review_status": {
            "type": "string",
            "enum": [
              "accepted_auto",
              "accepted_manual"
            ]
          },
          "evidence_level": {
            "$ref": "#/$defs/evidenceLevel"
          },
          "derived_from_attributes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "legacy_category",
                "legacy_light_preference_lux",
                "legacy_water_preference"
              ]
            },
            "uniqueItems": true
          },
          "special_handling": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
            },
            "uniqueItems": true
          },
          "manual_review_reasons": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
            },
            "uniqueItems": true
          },
          "provenance": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "source_file",
              "source_type",
              "match_type",
              "rule_id"
            ],
            "properties": {
              "source_file": {
                "type": "string",
                "minLength": 1
              },
              "source_type": {
                "type": "string",
                "enum": [
                  "legacy_backup_record"
                ]
              },
              "match_type": {
                "type": "string",
                "enum": [
                  "exact_common_name_and_scientific_name"
                ]
              },
              "rule_id": {
                "type": "string",
                "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "evidenceLevel": {
      "type": "string",
      "enum": [
        "legacy_backed",
        "experimentally_observed",
        "literature_backed",
        "inferred",
        "unresolved"
      ]
    },
    "identityProvenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_file",
        "source_type",
        "match_type"
      ],
      "properties": {
        "source_file": {
          "type": "string",
          "minLength": 1
        },
        "source_type": {
          "type": "string",
          "enum": [
            "legacy_backup_record"
          ]
        },
        "match_type": {
          "type": "string",
          "enum": [
            "exact_common_name_and_scientific_name"
          ]
        }
      }
    }
  }
}
