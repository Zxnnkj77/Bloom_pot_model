{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "controller_replay.schema.json",
  "title": "Bloom Pot Controller Replay Scenario",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "scenario_id",
    "plant_id",
    "initial_state",
    "observations"
  ],
  "properties": {
    "scenario_id": {
      "type": "string",
      "minLength": 1
    },
    "plant_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
    },
    "initial_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reservoir_ml"
      ],
      "properties": {
        "reservoir_ml": {
          "type": "number",
          "minimum": 0
        },
        "low_reading_count": {
          "type": "integer",
          "minimum": 0
        },
        "last_watered_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "daily_dose_ml": {
          "type": "number",
          "minimum": 0
        },
        "daily_dose_day": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        }
      }
    },
    "observations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "timestamp",
          "soil_moisture"
        ],
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "soil_moisture": {
            "type": "number"
          }
        }
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
