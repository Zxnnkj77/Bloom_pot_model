{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "plant_attributes.schema.json",
  "title": "Bloom Pot Plant Attributes",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "plant_id",
      "attributes"
    ],
    "properties": {
      "plant_id": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
      },
      "attributes": {
        "type": "array",
        "minItems": 1,
        "items": {
          "$ref": "#/$defs/attributeRecord"
        }
      }
    }
  },
  "$defs": {
    "evidenceLevel": {
      "type": "string",
      "enum": [
        "legacy_backed",
        "experimentally_observed",
        "literature_backed",
        "inferred",
        "unresolved"
      ]
    },
    "attributeProvenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_file",
        "source_type",
        "source_field"
      ],
      "properties": {
        "source_file": {
          "type": "string",
          "minLength": 1
        },
        "source_type": {
          "type": "string",
          "enum": [
            "legacy_backup_record"
          ]
        },
        "source_field": {
          "type": "string",
          "enum": [
            "category",
            "lightPreference",
            "waterPreference"
          ]
        }
      }
    },
    "legacyCategoryRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "value",
        "evidence_level",
        "used_for_controller_mapping",
        "provenance"
      ],
      "properties": {
        "name": {
          "const": "legacy_category"
        },
        "value": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
        },
        "evidence_level": {
          "$ref": "#/$defs/evidenceLevel"
        },
        "used_for_controller_mapping": {
          "type": "boolean"
        },
        "provenance": {
          "$ref": "#/$defs/attributeProvenance"
        }
      }
    },
    "legacyLightPreferenceRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "value",
        "evidence_level",
        "used_for_controller_mapping",
        "provenance"
      ],
      "properties": {
        "name": {
          "const": "legacy_light_preference_lux"
        },
        "value": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "evidence_level": {
          "$ref": "#/$defs/evidenceLevel"
        },
        "used_for_controller_mapping": {
          "type": "boolean"
        },
        "provenance": {
          "$ref": "#/$defs/attributeProvenance"
        }
      }
    },
    "legacyWaterPreferenceRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "value",
        "evidence_level",
        "used_for_controller_mapping",
        "provenance"
      ],
      "properties": {
        "name": {
          "const": "legacy_water_preference"
        },
        "value": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "evenly_moist",
            "dry_between",
            "drought_tolerant",
            "constantly_moist",
            null
          ]
        },
        "evidence_level": {
          "$ref": "#/$defs/evidenceLevel"
        },
        "used_for_controller_mapping": {
          "type": "boolean"
        },
        "provenance": {
          "$ref": "#/$defs/attributeProvenance"
        }
      }
    },
    "attributeRecord": {
      "oneOf": [
        {
          "$ref": "#/$defs/legacyCategoryRecord"
        },
        {
          "$ref": "#/$defs/legacyLightPreferenceRecord"
        },
        {
          "$ref": "#/$defs/legacyWaterPreferenceRecord"
        }
      ]
    }
  }
}
